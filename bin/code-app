#!/bin/bash


_usage() {
  # Print usage information
  cat << EOF
  Usage: code-app [-h|--help] [-p|--projects-folder PROJECTS_FOLDER] [-i|--instance INSTANCE_NAME] [-s|--stop] [DIRECTORY] [EXTRA_ARGS]

  Open the specified DIRECTORY in VSCode using the VSCode Apptainer image.

  If PROJECTS_FOLDER is specified, it will be used as the main folder for projects.
  Then DIRECTORY is expected to be relative to that directory.
  If neither are given, the current directory will be used as the project folder.

  EXTRA_ARGS are any additional arguments you want to pass to the 'code' command inside the container.

  Options:
    -h, --help                Show this help message and exit.
    -p, --projects-folder     Specify the main folder that you want to use for projects.
                              This will be mounted to a project mount folder inside the container.
                              If not specified, the DIRECTORY will be used as the project folder.
                              This can also be set with environment variable VSCODE_APP_PROJECT_DIR.
    -m, --projects-mount      Specify the mount point in the image for the projects folder.
                              Default is /project. This can also be set with environment variable
                              VSCODE_APP_PROJECT_MOUNT. Mount point needs to exist in the container image.
    -i, --instance            Specify the instance name for the Apptainer instance. Default is 'code'.
    -n, --no-instance         Do not use an Apptainer instance. Default is to use an instance.
    -c, --container-paths     Consider DIRECTORY to be a path as it would be appear inside the container.
                              E.g. /project/my-project would be converted to the corresponding host
                              path before launching the container.
    -s, --stop                Stop the Apptainer instance.
    -d, --debug               Print debug information.
    --wait                    Wait for the editor to exit.
    --rm                      Stop the instance once the editor exits. Implies --wait.
    --code-help               Pass the --help flag to the 'code' command inside the container.
  
  Example usage:
    code-app -p ~/projects my-project
    code-app .
    code-app -c $HOME
    VSCODE_APP_PROJECT_DIR=~/projects code-app my-project
EOF
}

VSCODE_APP_HOME_DIR="$VSCODE_APP_DATA_DIR/home"

_check_requirements() {
  # Check if apptainer is installed
  if ! command -v apptainer &> /dev/null; then
    echo "Error: apptainer is not installed. Please install apptainer to use code-app."
    exit 1
  fi
  # Check that VSCODE_APP_IMAGE environment variable is set
  if [ -z "$VSCODE_APP_IMAGE" ]; then
    echo "Error: VSCODE_APP_IMAGE environment variable is not set. Please set it to the path of the VSCode Apptainer image."
    exit 1
  fi
  # Check that VSCODE_APP_DATA_DIR environment variable is set
  if [ -z "$VSCODE_APP_DATA_DIR" ]; then
    echo "Error: VSCODE_APP_DATA_DIR environment variable is not set. Please set it to the path of the VSCode data directory."
    exit 1
  fi
  # Check that the VSCode Apptainer image exists
  if [ ! -f "$VSCODE_APP_IMAGE" ]; then
    echo "Error: The VSCode Apptainer image does not exist at $VSCODE_APP_IMAGE. Please make sure the image exists or update the VSCODE_APP_IMAGE environment variable to point to the correct location."
    exit 1
  fi
  # Check that the VSCode data directory exists
  if [ ! -d "$VSCODE_APP_DATA_DIR" ]; then
    echo "Error: The VSCode data directory does not exist at $VSCODE_APP_DATA_DIR. Please make sure the directory exists or update the VSCODE_APP_DATA_DIR environment variable to point to the correct location."
    exit 1
  fi
  # Check that VSCODE_APP_HOME_DIR exists, if not create it
  if [ ! -d "$VSCODE_APP_HOME_DIR" ]; then
    mkdir -p "$VSCODE_APP_HOME_DIR"
  fi
}

_check_requirements

VSCODE_APP_PROJECT_DIR="${VSCODE_APP_PROJECT_DIR:-$VSCODE_APP_PROJECT_DIR}"
VSCODE_APP_PROJECT_MOUNT="${VSCODE_APP_PROJECT_MOUNT:-/project}"

EXTRA_ARGS=()

INSTANCE_NAME="code"

# Check arguments for help flag and projects folder flag
while test $# -gt 0; do
  case $1 in
    -h|--help)
      _usage
      exit 0
      ;;
    -p|--projects-folder)
      # Store project folder
      VSCODE_APP_PROJECT_DIR="$2"
      shift 2
      ;;
    -m|--projects-mount)
      # Store project mount point
      VSCODE_APP_PROJECT_MOUNT="$2"
      shift 2
      ;;
    -i|--instance)
      # Store instance name
      INSTANCE_NAME="$2"
      shift 2
      ;;
    -c|--container-paths)
      VSCODE_CONTAINER_PATHS="true"
      shift
      ;;
    -n|--no-instance)
      VSCODE_NO_INSTANCE="true"
      shift
      ;;
    -s|--stop)
      # Stop the apptainer instance
      if apptainer instance list | cut -f 1 -d ' ' | grep -qP "^$INSTANCE_NAME$"; then
        apptainer instance stop "$INSTANCE_NAME"
      fi
      exit 0
      ;;
    -d|--debug)
      # Enable debug mode
      VSCODE_APP_DEBUG="true"
      shift
      ;;
    --wait)
      # Wait for the editor to exit
      VSCODE_APP_WAIT="true"
      shift
      ;;
    --rm)
      # Stop the instance once the editor exists
      VSCODE_APP_RM_ON_EXIT="true"
      VSCODE_APP_WAIT="true"
      shift
      ;;
    *)
      # Skip other arguments for now, we will capture them later
      EXTRA_ARGS+=("$1")
      shift
      ;;
  esac
done

# If extra arguments is empty, add the current directory to it
if [[ ${#EXTRA_ARGS[@]} -eq 0 ]]; then
  EXTRA_ARGS+=("$PWD")
fi

# Capture launch directory from the extra arguments
VSCODE_APP_LAUNCH_DIR=$(realpath "${EXTRA_ARGS[0]}")
EXTRA_ARGS=("${EXTRA_ARGS[@]:1}")

# Convert container paths to host paths if VSCODE_CONTAINER_PATHS is set.
if [[ ! -z "$VSCODE_CONTAINER_PATHS" ]]; then
  if [[ ! -z "$VSCODE_APP_DEBUG" ]]; then
    echo "Converting container paths to host paths:"
    echo "VSCODE_APP_LAUNCH_DIR (original):             " $VSCODE_APP_LAUNCH_DIR
  fi
  VSCODE_APP_LAUNCH_DIR=`echo "$VSCODE_APP_LAUNCH_DIR" | sed "s|$VSCODE_APP_PROJECT_MOUNT|$VSCODE_APP_PROJECT_DIR|g" | sed "s|$HOME|$VSCODE_APP_HOME_DIR|g"`
  if [[ ! -z "$VSCODE_APP_DEBUG" ]]; then
    echo "VSCODE_APP_LAUNCH_DIR (converted):            " $VSCODE_APP_LAUNCH_DIR
  fi
fi

# Check that the launch directory exists
if [ ! -d "$VSCODE_APP_LAUNCH_DIR" ]; then
  echo "Error: $VSCODE_APP_LAUNCH_DIR does not exist. Please make sure the directory exists."
  exit 1
fi

# If VSCODE_APP_PROJECT_DIR is not set, use the launch directory as the project directory
if [ -z "$VSCODE_APP_PROJECT_DIR" ]; then
  VSCODE_APP_PROJECT_DIR=$VSCODE_APP_LAUNCH_DIR
fi

# Check that the project directory exists
if [ ! -d "$VSCODE_APP_PROJECT_DIR" ]; then
  echo "Error: $VSCODE_APP_PROJECT_DIR does not exist. Please make sure the directory exists."
  exit 1
fi

# Determine real path for the VSCODE_APP_PROJECT_DIR
VSCODE_APP_PROJECT_DIR=$(realpath "$VSCODE_APP_PROJECT_DIR")

# Check that the launch directory is within the project directory or $VSCODE_APP_HOME_DIR folder
if [[ "$VSCODE_APP_LAUNCH_DIR" != "$VSCODE_APP_PROJECT_DIR"* && "$VSCODE_APP_LAUNCH_DIR" != "$VSCODE_APP_HOME_DIR"* ]]; then
  echo "Error: The launch directory $VSCODE_APP_LAUNCH_DIR is not within the project directory $VSCODE_APP_PROJECT_DIR or the fake home directory $VSCODE_APP_HOME_DIR. Please make sure the launch directory is within the project directory or the home directory."
  exit 1
fi

# Change the launch directory to be relative path towards project folder or /home in the container
VSCODE_APP_LAUNCH_DIR_ORIGINAL="$VSCODE_APP_LAUNCH_DIR"
VSCODE_APP_LAUNCH_DIR=`echo "$VSCODE_APP_LAUNCH_DIR" | sed "s|$VSCODE_APP_PROJECT_DIR|$VSCODE_APP_PROJECT_MOUNT|g" | sed "s|$VSCODE_APP_HOME_DIR|$HOME|g"`

# Debug prints
if [[ ! -z "$VSCODE_APP_DEBUG" ]]; then
  echo "Launching code-shell with the following configuration:"
  echo "VSCODE_APP_LAUNCH_DIR:                        " $VSCODE_APP_LAUNCH_DIR_ORIGINAL
  echo "VSCODE_APP_LAUNCH_DIR (within container):     " $VSCODE_APP_LAUNCH_DIR
  echo "VSCODE_APP_PROJECT_DIR:                       " $VSCODE_APP_PROJECT_DIR
  echo "VSCODE_APP_PROJECT_DIR (within container):    " $VSCODE_APP_PROJECT_MOUNT
  echo "VSCODE_APP_HOME_DIR:                          " $VSCODE_APP_HOME_DIR
  echo "VSCODE_APP_HOME_DIR (within container: /home):" $HOME
  echo "VSCODE_APP_TERMINAL:                          " $VSCODE_APP_TERMINAL
  set -x
fi

# Check if /run/user/$(id -u) exists and mount it if it does.
if [[ -d "/run/user/$(id -u)" ]]; then
  export APPTAINER_BIND="${APPTAINER_BIND}${APPTAINER_BIND:+,}/run/user/$(id -u)"
fi

# Check if /run/dbus exists and mount it if it does.
if [[ -d "/run/dbus" ]]; then
  export APPTAINER_BIND="${APPTAINER_BIND}${APPTAINER_BIND:+,}/run/dbus"
fi

# Add the project directory and fake home directory to the binds
export APPTAINER_BIND="${APPTAINER_BIND}${APPTAINER_BIND:+,}$VSCODE_APP_PROJECT_DIR:$VSCODE_APP_PROJECT_MOUNT"
export APPTAINER_BIND="${APPTAINER_BIND}${APPTAINER_BIND:+,}$VSCODE_APP_HOME_DIR:$HOME"

if [[ ! -z "$VSCODE_NO_INSTANCE" ]]; then
  # Start vscode in the container without using an instance
  apptainer exec --no-home --cwd $VSCODE_APP_PROJECT_MOUNT $VSCODE_APP_IMAGE code --wait "$VSCODE_APP_LAUNCH_DIR" "${EXTRA_ARGS[@]}"
else
  # Check if the apptainer instance is already running, if not start it
  if ! apptainer instance list | cut -f 1 -d ' ' | grep -qP "^$INSTANCE_NAME$"; then
    apptainer instance start --no-home  $VSCODE_APP_IMAGE "$INSTANCE_NAME"
  fi

  # Start vscode in the instance
  apptainer exec --cwd $VSCODE_APP_PROJECT_MOUNT instance://"$INSTANCE_NAME" code --wait "$VSCODE_APP_LAUNCH_DIR" "${EXTRA_ARGS[@]}" &

  # Wait on exit of the editor if the flag is set
  if [[ ! -z "$VSCODE_APP_WAIT" ]]; then
    wait $!
  fi

  # Stop the apptainer instance
  if [[ ! -z "$VSCODE_APP_RM_ON_EXIT" ]]; then
    apptainer instance stop "$INSTANCE_NAME"
  fi
fi
